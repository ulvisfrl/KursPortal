<!-- CALL TO ACTION (CTA) -->
<section class="py-24 bg-indigo-600 relative overflow-hidden">
    <div class="container mx-auto px-6 relative z-10 text-center">
        <h2 class="text-4xl lg:text-5xl font-black text-white mb-8">Bu gün başlayın, karyeranızı zirvəyə daşıyın</h2>
        <p class="text-indigo-100 text-lg mb-12 max-w-2xl mx-auto">Təlimlərimiz bitdikdən sonra sizə rəsmi sertifikat təqdim olunur və işlə təmin olunma şansı qazanırsınız.</p>
        <div class="flex justify-center">
            <a href="#" class="bg-white text-indigo-600 px-12 py-5 rounded-[2rem] font-black text-xl shadow-2xl hover:scale-105 transition-transform">
                İndi Qoşul <i class="fas fa-bolt ml-2"></i>
            </a>
        </div>
    </div>
    <!-- Decorative background circle -->
    <div class="absolute top-0 right-0 w-96 h-96 bg-white/10 rounded-full -translate-y-1/2 translate-x-1/2"></div>
</section>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        const testimonialContainer = document.getElementById("testimonialContainer");
        const slides = document.querySelectorAll("#testimonialContainer > div");
        const dotsContainer = document.getElementById("testimonialDots");

        let currentIndex = 0;
        const totalSlides = slides.length;

        // Dot yarat
        for (let i = 0; i < totalSlides; i++) {

            const dot = document.createElement("button");

            dot.className =
                "w-3 h-3 rounded-full bg-slate-300 transition-all duration-300";

            dot.addEventListener("click", () => {
                currentIndex = i;
                updateSlider();
            });

            dotsContainer.appendChild(dot);
        }

        const dots = dotsContainer.querySelectorAll("button");

        function updateSlider() {

            testimonialContainer.style.transform =
                `translateX(-${currentIndex * 100}%)`;

            dots.forEach((dot, index) => {

                if (index === currentIndex) {

                    dot.classList.remove("bg-slate-300");
                    dot.classList.add("bg-indigo-600", "w-8");

                } else {

                    dot.classList.remove("bg-indigo-600", "w-8");
                    dot.classList.add("bg-slate-300");
                }
            });
        }

        // GLOBAL ET
        window.nextTestimonial = function () {

            currentIndex++;

            if (currentIndex >= totalSlides) {
                currentIndex = 0;
            }

            updateSlider();
        }

        window.prevTestimonial = function () {

            currentIndex--;

            if (currentIndex < 0) {
                currentIndex = totalSlides - 1;
            }

            updateSlider();
        }

        // Auto slide
        setInterval(() => {
            nextTestimonial();
        }, 5000);

        updateSlider();

    });
</script>