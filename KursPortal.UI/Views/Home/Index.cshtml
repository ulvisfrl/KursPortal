<section id="home" class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 hero-gradient overflow-hidden">
    <div class="shape-blob bg-indigo-400 w-64 h-64 top-20 right-20"></div>
    <div class="shape-blob bg-cyan-300 w-72 h-72 bottom-10 left-10" style="animation-delay: -5s"></div>

    <div class="container mx-auto px-6 grid lg:grid-cols-2 gap-12 items-center">
        <div>
            <span class="inline-block px-4 py-1.5 mb-6 text-sm font-bold tracking-wider text-indigo-600 uppercase bg-indigo-50 rounded-full">
                🚀 Təhsildə Yeni Era
            </span>
            <h1 class="text-5xl lg:text-7xl font-extrabold leading-[1.1] mb-8 text-slate-900">
                Gələcəyinizi <br>
                <span class="text-indigo-600">Bizimlə Qurun</span>
            </h1>
            <p class="text-lg text-slate-600 mb-10 max-w-lg leading-relaxed">
                Ən müasir texnologiyalar və sahəsində mütəxəssis olan müəllimlərlə karyeranızı yüksəldin. Bu gün öyrənin, sabah rəhbərlik edin.
            </p>
            <div class="flex flex-wrap gap-5">
                <a href="#courses" class="btn-gradient text-white px-10 py-4 rounded-2xl font-bold text-lg shadow-xl hover:scale-105 transition-all">
                    Kursları Kəşf Et
                </a>
                <a href="#" class="bg-white text-slate-900 border border-slate-200 px-10 py-4 rounded-2xl font-bold text-lg hover:bg-slate-50 transition-all flex items-center gap-2">
                    <i class="fas fa-play-circle text-indigo-600"></i> Video İcmal
                </a>
            </div>

            <div class="mt-12 flex items-center gap-6">
                <div class="flex -space-x-3">
                    <img src="https://i.pravatar.cc/150?u=1" class="w-12 h-12 rounded-full border-4 border-white shadow-sm" alt="User">
                    <img src="https://i.pravatar.cc/150?u=2" class="w-12 h-12 rounded-full border-4 border-white shadow-sm" alt="User">
                    <img src="https://i.pravatar.cc/150?u=3" class="w-12 h-12 rounded-full border-4 border-white shadow-sm" alt="User">
                    <div class="w-12 h-12 rounded-full bg-indigo-600 border-4 border-white flex items-center justify-center text-white text-xs font-bold shadow-sm">
                        +10k
                    </div>
                </div>
                <p class="text-sm font-medium text-slate-500">
                    <span class="text-slate-900 font-bold">10,000+</span> tələbə bizə güvəndi
                </p>
            </div>
        </div>

        <div class="relative lg:block">
            <div class="relative z-10 rounded-3xl overflow-hidden shadow-2xl border-8 border-white/50">
                <img src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?w=800&q=80" alt="Education" class="w-full">
            </div>
            <!-- Floating Card -->
            <div class="absolute -bottom-10 -left-10 bg-white p-6 rounded-2xl shadow-xl z-20 animate-bounce-slow">
                <div class="flex items-center gap-4">
                    <div class="bg-green-100 p-3 rounded-xl text-green-600">
                        <i class="fas fa-check-circle text-2xl"></i>
                    </div>
                    <div>
                        <p class="text-xs text-slate-400 font-bold uppercase">Sertifikat</p>
                        <p class="text-slate-800 font-extrabold text-lg">Beynəlxalq Dərəcəli</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-12 bg-white">
    <div class="container mx-auto px-6">
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
            <div class="text-center p-6 border-r border-slate-100 last:border-0">
                <h3 class="text-4xl font-extrabold text-indigo-600 mb-1">50+</h3>
                <p class="text-slate-500 font-medium">Aktiv Kurslar</p>
            </div>
            <div class="text-center p-6 border-r border-slate-100 last:border-0">
                <h3 class="text-4xl font-extrabold text-indigo-600 mb-1">12k+</h3>
                <p class="text-slate-500 font-medium">Məzunlar</p>
            </div>
            <div class="text-center p-6 border-r border-slate-100 last:border-0">
                <h3 class="text-4xl font-extrabold text-indigo-600 mb-1">98%</h3>
                <p class="text-slate-500 font-medium">Məmnuniyyət</p>
            </div>
            <div class="text-center p-6">
                <h3 class="text-4xl font-extrabold text-indigo-600 mb-1">24/7</h3>
                <p class="text-slate-500 font-medium">Dəstək</p>
            </div>
        </div>
    </div>
</section>

<!-- POPULAR COURSES -->

@await Component.InvokeAsync("_PopularCourses");

<!-- INSTRUCTORS SECTION -->
@await Component.InvokeAsync("_Instructors");
<!-- CALL TO ACTION (CTA) -->
<section class="py-24 bg-indigo-600 relative overflow-hidden">
    <div class="container mx-auto px-6 relative z-10 text-center">
        <h2 class="text-4xl lg:text-5xl font-black text-white mb-8">Bu gün başlayın, karyeranızı zirvəyə daşıyın</h2>
        <p class="text-indigo-100 text-lg mb-12 max-w-2xl mx-auto">Təlimlərimiz bitdikdən sonra sizə rəsmi sertifikat təqdim olunur və işlə təmin olunma şansı qazanırsınız.</p>
        <div class="flex justify-center">
            <a href="#" class="bg-white text-indigo-600 px-12 py-5 rounded-[2rem] font-black text-xl shadow-2xl hover:scale-105 transition-transform">
                İndi Qoşul <i class="fas fa-bolt ml-2"></i>
            </a>
        </div>
    </div>
    <!-- Decorative background circle -->
    <div class="absolute top-0 right-0 w-96 h-96 bg-white/10 rounded-full -translate-y-1/2 translate-x-1/2"></div>
</section>