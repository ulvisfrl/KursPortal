@model ResultCourseVM

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<main class="flex-grow">
    <div class="bg-slate-900 text-white pt-20 pb-40 relative overflow-hidden">
        <div class="absolute top-0 right-0 w-1/2 h-full bg-blue-600/10 blur-[120px] rounded-full translate-x-1/2 -translate-y-1/2"></div>
        <div class="absolute bottom-0 left-0 w-1/4 h-1/2 bg-indigo-600/10 blur-[100px] rounded-full -translate-x-1/2 translate-y-1/2"></div>

        <div class="container mx-auto px-6 relative z-10">
            <div class="max-w-4xl">
                <nav class="flex mb-8 text-sm font-medium">
                    <a href="courses.html" class="text-blue-400 hover:text-blue-300 transition">Kurslar</a>
                    <span class="mx-3 text-slate-600">/</span>
                    <span class="text-slate-400"></span>
                </nav>
                <h1 class="text-5xl md:text-7xl font-extrabold mb-8 leading-[1.1] tracking-tight">
                    @Model.Title
                </h1>
                <p class="text-xl text-slate-300 mb-10 leading-relaxed max-w-3xl">
                    @Model.ShortDescription
                </p>

                <div class="flex flex-wrap gap-10">
                    <div class="flex items-center gap-3">
                        <div class="flex text-yellow-400">
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star"></i>
                        </div>
                        <span class="font-bold">4.9</span>
                        <span class="text-slate-400">(2,500+ rəy)</span>
                    </div>
                    <div class="flex items-center gap-2">
                        <i class="fas fa-user-friends text-blue-400"></i>
                        <span class="font-bold">12,450+</span>
                        <span class="text-slate-400">Tələbə</span>
                    </div>
                    <div class="flex items-center gap-2">
                        <i class="fas fa-certificate text-indigo-400"></i>
                        <span class="font-bold">Sertifikatlı</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="container mx-auto px-6 -mt-32 pb-24 relative z-20">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">

            <div class="lg:col-span-8 space-y-10">

                <div class="bg-white rounded-[2.5rem] p-10 shadow-xl shadow-slate-200/50 border border-slate-100">
                    <h2 class="text-3xl font-bold text-slate-900 mb-8">Kurs haqqında</h2>
                    <div class="prose prose-slate max-w-none text-slate-600 space-y-6 text-lg leading-relaxed">
                        <p>
                            @Model.LongDescription
                        </p>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 my-10">
                            <div class="flex gap-4 p-5 rounded-2xl bg-blue-50/50 border border-blue-100">
                                <i class="fas fa-check-circle text-blue-600 mt-1 text-xl"></i>
                                <span class="text-slate-800 font-medium">Panda və NumPy ilə böyük məlumat bazalarını idarə etmək</span>
                            </div>
                            <div class="flex gap-4 p-5 rounded-2xl bg-blue-50/50 border border-blue-100">
                                <i class="fas fa-check-circle text-blue-600 mt-1 text-xl"></i>
                                <span class="text-slate-800 font-medium">Scikit-learn ilə prediktiv modellər qurmaq</span>
                            </div>
                            <div class="flex gap-4 p-5 rounded-2xl bg-blue-50/50 border border-blue-100">
                                <i class="fas fa-check-circle text-blue-600 mt-1 text-xl"></i>
                                <span class="text-slate-800 font-medium">Matplotlib və Seaborn ilə vizuallaşdırma</span>
                            </div>
                            <div class="flex gap-4 p-5 rounded-2xl bg-blue-50/50 border border-blue-100">
                                <i class="fas fa-check-circle text-blue-600 mt-1 text-xl"></i>
                                <span class="text-slate-800 font-medium">Real biznes keysləri üzərində təcrübə</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Instructor Section -->
                <div class="bg-white rounded-[2.5rem] p-10 shadow-xl shadow-slate-200/50 border border-slate-100 overflow-hidden relative">
                    <div class="absolute top-0 right-0 p-8 opacity-5">
                        <i class="fas fa-quote-right text-9xl"></i>
                    </div>
                    <h2 class="text-3xl font-bold text-slate-900 mb-10 flex items-center gap-4">
                        Təlimçi ilə tanış olun
                    </h2>
                    <div class="flex flex-col md:flex-row items-start gap-10">
                        <div class="relative shrink-0">
                            <div class="w-40 h-40 rounded-3xl overflow-hidden shadow-2xl rotate-3 hover:rotate-0 transition-transform duration-500">
                                <img src="https://images.unsplash.com/photo-1560250097-0b93528c311a?w=400&q=80" class="w-full h-full object-cover" alt="Təlimçi">
                            </div>
                            <div class="absolute -bottom-4 -right-4 bg-indigo-600 text-white p-3 rounded-2xl shadow-xl">
                                <i class="fas fa-award text-xl"></i>
                            </div>
                        </div>
                        <div class="space-y-4">
                            <div>
                                <h4 class="text-2xl font-bold text-slate-900">@Model.TeacherName</h4>
                                <p class="text-blue-600 font-bold uppercase tracking-widest text-xs mt-1">Lead Data Scientist</p>
                            </div>
                            <p class="text-slate-600 text-lg leading-relaxed">
                                Elvin, Silicon Valley-də fəaliyyət göstərən aparıcı texnoloji şirkətlərlə əməkdaşlıq etmiş bir mütəxəssisdir. O, mürəkkəb riyazi alqoritmləri hər kəsin başa düşəcəyi dildə izah etmək bacarığı ilə tanınır.
                            </p>
                            <div class="flex gap-6 pt-4">
                                <div class="text-center">
                                    <div class="text-2xl font-bold text-slate-900">10k+</div>
                                    <div class="text-xs text-slate-400 font-bold uppercase">Məzun</div>
                                </div>
                                <div class="w-px h-10 bg-slate-100"></div>
                                <div class="text-center">
                                    <div class="text-2xl font-bold text-slate-900">12</div>
                                    <div class="text-xs text-slate-400 font-bold uppercase">İllik Təcrübə</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- RIGHT SIDE: Sticky Purchase Sidebar -->
            <div class="lg:col-span-4">
                <div class="sticky top-28 space-y-8">

                    <!-- Purchase Card -->
                    <div class="bg-white rounded-[2.5rem] p-8 shadow-2xl shadow-blue-900/10 border border-slate-100 overflow-hidden relative">
                        <!-- Preview Image/Video -->
                        <div class="relative rounded-3xl overflow-hidden mb-8 aspect-video group">
                            <img src="https://images.unsplash.com/photo-1526374965328-7f61d4dc18c5?w=600&q=80" class="w-full h-full object-cover transform group-hover:scale-110 transition duration-700">
                            <div class="absolute inset-0 bg-slate-900/40 flex items-center justify-center">
                                <button class="w-16 h-16 bg-white rounded-full flex items-center justify-center text-blue-600 shadow-2xl hover:scale-110 transition duration-300">
                                    <i class="fas fa-play ml-1 text-xl"></i>
                                </button>
                            </div>
                            <div class="absolute top-4 left-4 bg-white/90 backdrop-blur px-3 py-1 rounded-full text-xs font-bold text-slate-900">
                                Önizləmə dərsi
                            </div>
                        </div>

                        <div class="space-y-6">
                            <div class="flex items-center justify-between">
                                <div class="space-y-1">
                                    <p class="text-slate-400 text-sm font-medium line-through">@Model.Price AZN</p>
                                    <h3 class="text-4xl font-extrabold text-slate-900">@Model.DiscountPrice AZN</h3>
                                </div>
                                <span class="bg-red-100 text-red-600 text-sm font-black px-4 py-2 rounded-2xl">
                                    -33%
                                </span>
                            </div>

                            <div class="grid grid-cols-1 gap-4">
                                <button class="w-full bg-blue-600 text-white py-5 rounded-[1.25rem] font-bold text-lg hover:bg-blue-700 transition-all shadow-xl shadow-blue-200 active:scale-95">
                                    Kursa qoşul
                                </button>
                                <button class="w-full border-2 border-slate-200 text-slate-900 py-5 rounded-[1.25rem] font-bold text-lg hover:bg-slate-50 transition-all">
                                    Səbətə əlavə et
                                </button>
                            </div>

                            <div class="space-y-4 pt-8">
                                <h4 class="text-sm font-black text-slate-900 uppercase tracking-widest flex items-center gap-2">
                                    <span class="w-1.5 h-1.5 bg-blue-600 rounded-full"></span>
                                    Kursa daxildir
                                </h4>
                                <ul class="space-y-4">
                                    <li class="flex items-center gap-4 text-slate-600">
                                        <div class="w-8 h-8 rounded-lg bg-blue-50 flex items-center justify-center text-blue-600 shrink-0">
                                            <i class="fas fa-infinity text-sm"></i>
                                        </div>
                                        <span class="text-sm font-medium">Ömürlük tam daxilolma</span>
                                    </li>
                                    <li class="flex items-center gap-4 text-slate-600">
                                        <div class="w-8 h-8 rounded-lg bg-blue-50 flex items-center justify-center text-blue-600 shrink-0">
                                            <i class="fas fa-file-download text-sm"></i>
                                        </div>
                                        <span class="text-sm font-medium">25+ Yüklənə bilən resurs</span>
                                    </li>
                                    <li class="flex items-center gap-4 text-slate-600">
                                        <div class="w-8 h-8 rounded-lg bg-blue-50 flex items-center justify-center text-blue-600 shrink-0">
                                            <i class="fas fa-certificate text-sm"></i>
                                        </div>
                                        <span class="text-sm font-medium">Rəsmi bitirmə sertifikatı</span>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <!-- Secondary Feature Card -->
                    <div class="bg-indigo-900 rounded-[2.5rem] p-8 text-white relative overflow-hidden">
                        <i class="fas fa-rocket absolute -right-4 -bottom-4 text-7xl opacity-10 -rotate-12"></i>
                        <h4 class="text-xl font-bold mb-3">Karyera Dəstəyi</h4>
                        <p class="text-indigo-200 text-sm leading-relaxed mb-6">
                            Kursu bitirdikdən sonra biz sizə CV hazırlamaqda və iş müsahibələrində kömək edirik.
                        </p>
                        <a href="#" class="text-white font-bold text-sm border-b-2 border-indigo-400 pb-1 hover:border-white transition">Daha çox öyrən</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>
}
