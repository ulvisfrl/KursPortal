@model List<AppUser>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<header class="pt-32 pb-16 bg-gradient-to-b from-indigo-50/50 to-transparent">
    <div class="container mx-auto px-6 text-center">
        <h1 class="text-4xl lg:text-5xl font-extrabold text-slate-900 mb-4">Peşəkar Təlimçilərimiz</h1>
        <p class="text-lg text-slate-600 max-w-2xl mx-auto">
            Sahəsində illərlə təcrübəsi olan mütəxəssislərdən öyrənin. Bizim müəllimlər yalnız nəzəriyyəni deyil, həm də real iş təcrübəsini bölüşürlər.
        </p>
    </div>
</header>

<section class="container mx-auto px-6 mb-12">
    <div class="bg-white p-4 rounded-3xl shadow-sm border border-slate-100 flex flex-wrap gap-2 justify-center items-center">
        <form method="post" asp-action="Search" asp-controller="Instructor">
        <div class="relative w-full md:w-72 group">
            <i class="fas fa-search absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-indigo-600 transition-colors"></i>
            <input name="term" type="text" placeholder="Müəllim axtar..." class="w-full bg-slate-50 border border-slate-100 rounded-2xl py-3 pl-11 pr-4 text-sm font-medium outline-none focus:bg-white focus:border-indigo-600 focus:ring-4 focus:ring-indigo-50 transition-all">
        </div>
        </form>
        <main class="w-full mt-12 grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
            @foreach(var item in Model)
            {
                <div class="instructor-card bg-white p-8 rounded-[2.5rem] text-center border border-slate-100" data-category="data">
                    <div class="relative w-32 h-32 mx-auto mb-6">
                        <img src="@item.ProfilePicture" class="w-full h-full rounded-full border-4 border-white object-cover shadow-md" alt="Nigar">
                        <div class="absolute bottom-0 right-0 bg-green-500 w-5 h-5 rounded-full border-2 border-white"></div>
                    </div>
                    <h4 class="text-xl font-bold text-slate-900 mb-1">@item.FirsName @item.LastName</h4>
                    <p class="text-indigo-600 font-semibold text-sm mb-4">@item.Profession</p>
                    <p class="text-slate-500 text-sm mb-6">@item.ProfessionalTitle</p>
                    <div class="flex justify-center gap-4 border-t pt-6">
                        <i class="fab fa-linkedin text-slate-400 hover:text-indigo-600 cursor-pointer"></i>
                        <i class="fas fa-envelope text-slate-400 hover:text-indigo-600 cursor-pointer"></i>
                    </div>
                </div>

            }
        </main>
    </div>
</section>
