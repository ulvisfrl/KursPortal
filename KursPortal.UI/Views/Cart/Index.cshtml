@model ResultCartVM

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<main class="flex-grow py-10">
    <div class="container mx-auto px-6 max-w-6xl">

        <!-- STEPS -->
        <div class="flex items-center justify-center mb-10 space-x-4 text-sm md:text-base">
            <div class="flex items-center step-active">
                <span class="w-8 h-8 rounded-full border-2 border-blue-600 flex items-center justify-center mr-2">1</span>
                Səbət
            </div>
            <div class="h-px w-12 bg-gray-300"></div>
            <div class="flex items-center step-inactive">
                <span class="w-8 h-8 rounded-full border-2 border-gray-300 flex items-center justify-center mr-2">2</span>
                Ödəniş
            </div>
            <div class="h-px w-12 bg-gray-300"></div>
            <div class="flex items-center step-inactive">
                <span class="w-8 h-8 rounded-full border-2 border-gray-300 flex items-center justify-center mr-2">3</span>
                Tamamlandı
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

            <div class="lg:col-span-2 space-y-6">

                <div class="bg-blue-50 border-l-4 border-blue-500 p-4 rounded-r-xl">
                    <div class="flex items-center">
                        <i class="fas fa-info-circle text-blue-500 mr-3"></i>
                        <p class="text-sm text-blue-800 font-medium">
                            Eyni anda yalnız 1 kurs ala bilərsiniz.
                        </p>
                    </div>
                </div>

                <!-- CART -->
                <section class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 md:p-8">

                    <h2 class="text-2xl font-bold text-gray-800 mb-6 flex items-center gap-2">
                        <i class="fas fa-shopping-cart text-blue-600"></i> Səbətim
                    </h2>

                    @if (Model?.CartItems != null && Model.CartItems.Any())
                    {
                        foreach (var item in Model.CartItems)
                        {
                            <div class="flex flex-col md:flex-row gap-6 pb-6 border-b border-gray-100 mb-6">

                                <!-- IMAGE -->
                                <img src="@item.ImageUrl"
                                     class="w-full md:w-48 h-32 object-cover rounded-2xl shadow-sm" />

                                <!-- INFO -->
                                <div class="flex-grow flex flex-col justify-between">

                                    <div class="flex justify-between items-start">

                                        <div>
                                            <h4 class="font-bold text-xl text-gray-800">
                                                @item.Title
                                            </h4>

                                            <p class="text-sm text-gray-500 mt-1">
                                                Online Kurs
                                            </p>
                                        </div>

                                        <form asp-controller="Cart" asp-action="Remove" method="post">
                                            <input type="hidden" name="courseId" value="@item.CourseId" />
                                            <button class="text-gray-400 hover:text-red-500 p-2">
                                                <i class="fas fa-times text-lg"></i>
                                            </button>
                                        </form>

                                    </div>

                                    <div class="flex justify-between items-center mt-6">

                                        <span class="text-xs font-bold text-blue-600 bg-blue-50 px-3 py-1 rounded-full uppercase">
                                            Video Kurs
                                        </span>

                                        <span class="text-2xl font-black text-gray-900">
                                            @item.Price AZN
                                        </span>

                                    </div>

                                </div>
                            </div>
                        }

                        <div class="mt-6 flex justify-end">
                            <form asp-controller="Cart" asp-action="Clear" method="post">
                                <button class="text-red-600 font-semibold flex items-center gap-2">
                                    <i class="fas fa-trash-alt"></i> Səbəti tam sil
                                </button>
                            </form>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-10 text-gray-500">
                            Səbət boşdur
                        </div>
                    }

                    <div class="mt-8 flex flex-col md:flex-row justify-between items-center gap-6">

                        <a asp-controller="Course" asp-action="Index"
                           class="text-gray-500 font-semibold hover:text-blue-600 flex items-center gap-2">
                            <i class="fas fa-arrow-left text-sm"></i> Kurslara qayıt
                        </a>

                        <button class="w-full md:w-auto bg-blue-600 text-white px-10 py-4 rounded-xl font-bold hover:bg-blue-700">
                            Ödənişə keç
                        </button>

                    </div>

                </section>
            </div>

            <!-- RIGHT -->
            <div class="lg:col-span-1">

                <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 sticky top-24">

                    <h3 class="font-bold text-xl text-gray-800 mb-6 border-b pb-4">
                        Sifariş Xülasəsi
                    </h3>

                    <div class="space-y-4">

                        <div class="flex justify-between text-gray-500">
                            <span>Ümumi</span>
                            <span>
                                @Model?.CartItems?.Sum(x => x.Price) AZN
                            </span>
                        </div>

                    </div>

                </div>

            </div>

        </div>
    </div>
</main>