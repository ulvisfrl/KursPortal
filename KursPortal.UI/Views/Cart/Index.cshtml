@model ResultCartVM

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<main class="flex-grow py-10">
    <div class="container mx-auto px-6 max-w-6xl">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            @if (Model?.CartItems != null && Model.CartItems.Any())
            {
                <div class="lg:col-span-2 space-y-6">
                    <br />
                    <br />
                    <br />
                    <section class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 md:p-8">
                        <h2 class="text-2xl font-bold text-gray-800 mb-6 flex items-center gap-2">
                            <i class="fas fa-shopping-cart text-blue-600"></i> Səbətim
                        </h2>

                        @foreach (var item in Model.CartItems)
                        {
                            <div class="relative flex flex-col md:flex-row gap-6 pb-6 border-b border-gray-100 mb-6">

                                <!-- REMOVE BUTTON (top-right absolute) -->
                                <form asp-controller="Cart" asp-action="Remove" method="post"
                                      class="absolute top-3 right-3">
                                    <input type="hidden" name="courseId" value="@item.CourseId" />
                                    <button type="submit"
                                            class="w-9 h-9 flex items-center justify-center rounded-full bg-gray-100 hover:bg-red-100 text-gray-400 hover:text-red-600 transition">
                                        <i class="fas fa-times text-sm"></i>
                                    </button>
                                </form>

                                <!-- IMAGE -->
                                <img src="@item.ImageUrl"
                                     class="w-full md:w-48 h-32 object-cover rounded-2xl shadow-sm" />

                                <!-- INFO -->
                                <div class="flex-grow flex flex-col justify-between">

                                    <div>
                                        <h4 class="font-bold text-xl text-gray-800">
                                            @item.Title
                                        </h4>

                                        <p class="text-sm text-gray-500 mt-1">
                                            Online Kurs
                                        </p>
                                    </div>

                                    <div class="flex justify-between items-center mt-4">
                                        <span class="text-2xl font-black text-gray-900">
                                            @item.Price AZN
                                        </span>
                                    </div>

                                </div>
                            </div>
                        }

                        <div class="mt-6 flex justify-end">
                            <form asp-controller="Cart" asp-action="Clear" method="post">
                                <button class="text-red-600 font-semibold flex items-center gap-2">
                                    <i class="fas fa-trash-alt"></i> Səbəti tam sil
                                </button>
                            </form>
                        </div>

                        <div class="mt-8 flex flex-col md:flex-row justify-between items-center gap-6">
                            <a asp-controller="Course" asp-action="Index"
                               class="text-gray-500 font-semibold hover:text-blue-600 flex items-center gap-2">
                                <i class="fas fa-arrow-left text-sm"></i> Kurslara qayıt
                            </a>

                            <form asp-action="CreateOrder" asp-controller="Order" method="post">
                                <button type="submit"
                                        class="w-full md:w-auto bg-blue-600 text-white px-10 py-4 rounded-xl font-bold hover:bg-blue-700">
                                    Ödənişə keç
                                </button>
                            </form>
                        </div>

                    </section>
                </div>
                
                <div class="lg:col-span-1">
                    <br />
                    <br />
                    <br />
                    <br />
                  
                    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6 sticky top-24">
                        <h3 class="font-bold text-xl text-gray-800 mb-6 border-b pb-4">
                            Sifariş Xülasəsi
                        </h3>

                        <div class="flex justify-between text-gray-500">
                            <span>Ümumi</span>
                            <span>
                                @Model.CartItems.Sum(x => x.Price) AZN
                            </span>
                        </div>

                    </div>
                </div>
            }
            else
            {
                <br />
                <br />
                <br />
                <div class="lg:col-span-3 flex justify-center">
                    <div class="bg-white/80 backdrop-blur-md border border-white/40 rounded-3xl p-8 md:p-16 shadow-xl shadow-slate-100 max-w-2xl w-full text-center">

                        <!-- SVG Illustration -->
                        <div class="relative w-48 h-48 mx-auto mb-8 flex items-center justify-center">
                            <div class="absolute inset-0 bg-indigo-50 rounded-full scale-90 animate-pulse"></div>

                            <!-- Custom Modern SVG Shopping Basket -->
                            <svg class="w-32 h-32 text-indigo-600 relative z-10"
                                 fill="none"
                                 stroke="currentColor"
                                 viewBox="0 0 24 24"
                                 xmlns="http://www.w3.org/2000/svg">
                                <path stroke-linecap="round"
                                      stroke-linejoin="round"
                                      stroke-width="1.5"
                                      d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z">
                                </path>
                                <circle cx="12" cy="14" r="1.5" fill="currentColor"></circle>
                            </svg>

                            <!-- Floating Decorative Elements -->
                            <span class="absolute top-4 right-8 text-cyan-400 text-2xl animate-bounce">
                                <i class="fas fa-sparkles"></i>
                            </span>

                            <span class="absolute bottom-6 left-8 text-indigo-400 text-lg opacity-60">
                                <i class="fas fa-plus"></i>
                            </span>
                        </div>

                        <!-- Content -->
                        <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight mb-4">
                            Səbətiniz boşdur
                        </h1>

                        <p class="text-slate-500 font-medium leading-relaxed max-w-md mx-auto mb-10">
                            Görünür hələ heç bir kurs əlavə etməmisiniz.
                            Platformamızdakı minlərlə tələbəyə qoşulun və öyrənməyə bu gün başlayın!
                        </p>

                        <!-- CTA Actions -->
                        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
                            <a href="/courses"
                               class="btn-gradient text-white px-8 py-4 rounded-2xl font-bold shadow-lg shadow-indigo-200 hover:shadow-indigo-300 transition-all flex items-center justify-center gap-3 w-full sm:w-auto">
                                <i class="fas fa-search"></i>
                                Kursları Araşdır
                            </a>

                            <a href="/"
                               class="px-8 py-4 bg-slate-100 hover:bg-slate-200 text-slate-700 font-bold rounded-2xl transition-all flex items-center justify-center gap-2 w-full sm:w-auto">
                                Ana səhifəyə dön
                            </a>
                        </div>

                    </div>
                </div>
            }

        </div>
    </div>
</main>