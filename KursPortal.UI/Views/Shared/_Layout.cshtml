<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KursPortal | Gələcəyini Proqramlaşdır</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #4F46E5;
            --secondary: #06B6D4;
            --accent: #F43F5E;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            scroll-behavior: smooth;
        }

        .glass-nav {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1); /* Keçid sürəti və tipi */
            padding-top: 1.5rem; /* İlkin (böyük) ölçü */
            padding-bottom: 1.5rem;
        }

        .navbar-scrolled {
            padding-top: 0.75rem !important; /* Kiçik ölçü */
            padding-bottom: 0.75rem !important;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        }

        .hero-gradient {
            background: radial-gradient(circle at top right, rgba(79, 70, 229, 0.15), transparent), radial-gradient(circle at bottom left, rgba(6, 182, 212, 0.1), transparent);
        }

        .course-card:hover .course-img {
            transform: scale(1.1) rotate(2deg);
        }

        .btn-gradient {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            transition: all 0.3s ease;
        }

            .btn-gradient:hover {
                transform: translateY(-2px);
                box-shadow: 0 10px 20px -10px var(--primary);
            }

        .instructor-card {
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

            .instructor-card:hover {
                transform: translateY(-10px);
            }

        .shape-blob {
            position: absolute;
            filter: blur(40px);
            z-index: -1;
            opacity: 0.4;
            animation: move 20s infinite alternate;
        }



        @@keyframes move {
            from {
                transform: translate(0, 0);
            }

            to {
                transform: translate(100px, 50px);
            }
        }
    </style>
</head>
<body class="bg-slate-50 text-slate-900 overflow-x-hidden">

    <nav class="glass-nav fixed w-full z-[100] border-b border-white/20">
        <div class="container mx-auto px-6 flex justify-between items-center">
            <a href="/" class="flex items-center gap-2 group">
                <div class="bg-indigo-600 p-2 rounded-xl group-hover:rotate-12 transition-transform">
                    <i class="fas fa-rocket text-white text-xl"></i>
                </div>
                <span class="text-2xl font-extrabold tracking-tight bg-clip-text text-transparent bg-gradient-to-r from-indigo-600 to-cyan-500">
                    KursPortal
                </span>
            </a>

            <div class="hidden lg:flex items-center space-x-10 font-semibold text-slate-600">
                <a href="/" class="hover:text-indigo-600 transition-colors">Ana Səhifə</a>
                <a href="/courses" class="hover:text-indigo-600 transition-colors">Kurslar</a>
                <a href="/instructors" class="hover:text-indigo-600 transition-colors">Müəllimlər</a>
                <a href="/blogs" class="hover:text-indigo-600 transition-colors">Məqalələr</a>
                <a href="/about" class="hover:text-indigo-600 transition-colors">Haqqımızda</a>
                <a href="/contact" class="hover:text-indigo-600 transition-colors">Əlaqə</a>
                <a href="/faq" class="hover:text-indigo-600 transition-colors">FAQ</a>
            </div>
            @if (User.Identity.IsAuthenticated)
            {
                <div class="flex items-center gap-6">

                    <!-- Favorilər -->
                    @await Component.InvokeAsync("_Favorite")

                    <!-- Səbət -->
                    @await Component.InvokeAsync("_Basket")

                    <!-- Profil -->
                    <div class="ml-4">
                        @await Component.InvokeAsync("_UserProfile")
                    </div>

                </div>

            }
            else
            {
                <div class="flex items-center gap-4">
                    <a asp-controller="Account" asp-action="Login" asp-route-returnUrl ="@(Context.Request.Path + Context.Request.QueryString)" class="hidden sm:block font-bold text-slate-700 hover:text-indigo-600 px-4">Daxil ol</a>
                    <a href="/Account/Register" class="btn-gradient text-white px-7 py-2.5 rounded-full font-bold shadow-md">Qeydiyyat</a>
                </div>
            }
        </div>
    </nav>

    @RenderBody()


    <footer class="bg-slate-50 pt-24 pb-12">
        <div class="container mx-auto px-6">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-16 mb-20">
                <div class="col-span-1 lg:col-span-1">
                    <a href="#" class="flex items-center gap-2 mb-8">
                        <div class="bg-indigo-600 p-2 rounded-xl">
                            <i class="fas fa-rocket text-white text-xl"></i>
                        </div>
                        <span class="text-2xl font-extrabold tracking-tight">KursPortal</span>
                    </a>
                    <p class="text-slate-500 leading-relaxed mb-8">Azərbaycanın ən dinamik və modern onlayn təhsil platforması. Gələcəyin mütəxəssislərini yetişdiririk.</p>
                    <div class="flex gap-4">
                        <a href="#" class="w-10 h-10 rounded-full bg-slate-200 flex items-center justify-center text-slate-600 hover:bg-indigo-600 hover:text-white transition-all"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" class="w-10 h-10 rounded-full bg-slate-200 flex items-center justify-center text-slate-600 hover:bg-indigo-600 hover:text-white transition-all"><i class="fab fa-instagram"></i></a>
                        <a href="#" class="w-10 h-10 rounded-full bg-slate-200 flex items-center justify-center text-slate-600 hover:bg-indigo-600 hover:text-white transition-all"><i class="fab fa-linkedin-in"></i></a>
                    </div>
                </div>

                <div>
                    <h4 class="text-lg font-bold text-slate-900 mb-8">Keçidlər</h4>
                    <ul class="space-y-4 text-slate-500 font-medium">
                        <li><a href="/" class="hover:text-indigo-600 transition-colors">Ana Səhifə</a></li>
                        <li><a href="/courses" class="hover:text-indigo-600 transition-colors">Bütün Kurslar</a></li>
                        <li><a href="/faq" class="hover:text-indigo-600 transition-colors">Tez-tez verilən suallar</a></li>
                    </ul>
                </div>

                <div>
                    <h4 class="text-lg font-bold text-slate-900 mb-8">Kömək</h4>
                    <ul class="space-y-4 text-slate-500 font-medium">
                        <li><a href="/contact" class="hover:text-indigo-600 transition-colors">Dəstək Mərkəzi</a></li>
                        <li><a href="#" class="hover:text-indigo-600 transition-colors">Şərtlər və Qaydalar</a></li>
                        <li><a href="#" class="hover:text-indigo-600 transition-colors">Məxfilik Siyasəti</a></li>
                        <li><a href="#" class="hover:text-indigo-600 transition-colors">Geri qaytarılma</a></li>
                    </ul>
                </div>

                <div>
                    <h4 class="text-lg font-bold text-slate-900 mb-8">Bülletenə Qoşulun</h4>
                    <p class="text-slate-500 mb-6 font-medium">Yeni kurslar və endirimlər haqqında ilk siz xəbər tutun.</p>
                    <div class="relative">
                        <form method="post" asp-action="Index" asp-controller="Subscriber">
                            <input type="email" name="Email" placeholder="E-poçt ünvanınız" class="w-full bg-white border border-slate-200 rounded-2xl px-6 py-4 outline-none focus:border-indigo-600 transition-colors">
                            <button type="submit" class="absolute right-2 top-2 bg-indigo-600 text-white w-10 h-10 rounded-xl flex items-center justify-center hover:bg-indigo-700 transition-colors">
                                <i class="fas fa-paper-plane"></i>
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="border-t border-slate-200 pt-12 flex flex-col md:flex-row justify-between items-center gap-6">
                <p class="text-slate-400 text-sm font-bold">&copy; 2024 KursPortal Təhsil Mərkəzi. Bütün hüquqlar qorunur.</p>
                <div class="flex items-center gap-8">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/5/5e/Visa_Inc._logo.svg" class="h-4 opacity-50 grayscale hover:grayscale-0 transition-all cursor-pointer" alt="Visa">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/2/2a/Mastercard-logo.svg" class="h-6 opacity-50 grayscale hover:grayscale-0 transition-all cursor-pointer" alt="Mastercard">
                </div>
            </div>
        </div>
    </footer>

    <script>
                window.addEventListener('scroll', () => {
            const nav = document.querySelector('.glass-nav');
            if (window.scrollY > 20) {
                nav.classList.add('navbar-scrolled');
            } else {
                nav.classList.remove('navbar-scrolled');
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>