@model List<ResultCourseVM>

<section id="courses" class="py-24">
    <div class="container mx-auto px-6">
        <div class="flex flex-col md:flex-row justify-between items-end mb-16">
            <div class="max-w-2xl">
                <h2 class="text-4xl font-extrabold text-slate-900 mb-4">Populyar Kurslarımız</h2>
                <p class="text-slate-500 text-lg">Ən son texnologiyalar və peşəkar bacarıqlar üzrə ən çox tələb olunan kursları seçdik.</p>
            </div>
            <a href="#" class="mt-6 md:mt-0 group flex items-center gap-2 font-bold text-indigo-600">
                Bütün Kurslar <i class="fas fa-arrow-right group-hover:translate-x-2 transition-transform"></i>
            </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">

            @foreach (var item in Model)
            {
                @if(item.IsPopular == true)
                {
                    <div class="group course-card bg-white rounded-[2.5rem] overflow-hidden shadow-sm hover:shadow-2xl transition-all duration-500 border border-slate-100">
                        <div class="relative h-64 overflow-hidden">
                            <img src="@item.ImageUrl" class="course-img w-full h-full object-cover transition-transform duration-700" alt="UX Design">
                            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
                        </div>
                        <div class="p-8">
                            <div class="flex justify-between items-center mb-4">
                                <span class="text-xs font-extrabold text-rose-500 uppercase tracking-tighter">@item.CategoryName</span>
                                <div class="flex text-yellow-400 text-xs">
                                    <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star-half-alt"></i>
                                </div>
                            </div>
                            <h3 class="text-2xl font-extrabold text-slate-800 mb-4 group-hover:text-indigo-600 transition-colors">@item.Title</h3>
                            <div class="flex items-center gap-4 mb-6 text-slate-500 text-sm font-medium">
                                <span><i class="far fa-clock text-indigo-500 mr-1"></i> @item.CourseHour</span>
                            </div>
                            <div class="flex items-center justify-between border-t border-slate-50 pt-6">
                                <div>
                                    <p class="text-slate-400 text-xs font-bold line-through">@item.Price AZN</p>
                                    <p class="text-3xl font-black text-slate-900">@item.DiscountPrice <span class="text-lg font-bold">AZN</span></p>
                                </div>
                                <button class="bg-slate-900 text-white w-14 h-14 rounded-2xl flex items-center justify-center hover:bg-indigo-600 transition-colors shadow-lg shadow-slate-200">
                                    <i class="fas fa-shopping-bag text-xl"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                }
            }

        </div>
    </div>
</section>