@model List<AppUser>

<section id="instructors" class="py-24 bg-slate-900 text-white overflow-hidden">
    <div class="container mx-auto px-6">
        <div class="text-center max-w-3xl mx-auto mb-20">
            <h2 class="text-4xl lg:text-5xl font-extrabold mb-6 italic tracking-tight">Peşəkar Müəllim Heyəti</h2>
            <p class="text-slate-400 text-lg">Müəllimlərimiz yerli və beynəlxalq bazarda illərlə təcrübəsi olan real ekspertlərdir.</p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
                @foreach(var item in Model)
                {
                    <div class="instructor-card group text-center">
                        <div class="relative mb-6 mx-auto w-56 h-56">
                            <div class="absolute inset-0 bg-indigo-600 rounded-3xl rotate-6 group-hover:rotate-12 transition-transform duration-500"></div>
                            <img src="@item.ProfilePicture" class="absolute inset-0 w-full h-full object-cover rounded-3xl z-10 border-4 border-slate-800" alt="Müəllim">
                        </div>
                        <h4 class="text-2xl font-extrabold mb-1">@item.FirsName @item.LastName</h4>
                        <p class="text-indigo-400 font-bold text-sm uppercase tracking-widest mb-4">@item.Profession</p>
                        <div class="flex justify-center gap-4 text-slate-500">
                            <a href="#" class="hover:text-white transition-colors"><i class="fab fa-linkedin-in text-xl"></i></a>
                            <a href="#" class="hover:text-white transition-colors"><i class="fab fa-github text-xl"></i></a>
                        </div>
                    </div>

                }
        </div>
    </div>
</section>

