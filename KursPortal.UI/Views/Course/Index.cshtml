@model List<ResultCourseVM>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<br />
<br />
<br />
<br />
<main class="flex-grow py-12">
    <div class="container mx-auto px-6">
        <div class="max-w-4xl mx-auto text-center mb-10">
            <h1 class="text-4xl font-extrabold mb-6">Nə öyrənmək istəyirsiniz?</h1>
            <form method="post" asp-action="Search" asp-controller="Course">
            <div class="relative group">
                <input name="term" type="text" placeholder="Kursun adı, mövzu və ya təlimçi axtarın..."
                       class="w-full pl-14 pr-6 py-5 bg-white border-2 border-gray-200 focus:border-blue-500 rounded-2xl shadow-sm outline-none transition-all text-lg">
                <i class="fas fa-search absolute left-6 top-1/2 -translate-y-1/2 text-gray-400 group-focus-within:text-blue-600 text-xl transition-colors"></i>
            </div>
            </form>
        </div>

        

        @if (TempData["Error"] != null)
        {
            <div id="alertBox" class="max-w-4xl mx-auto mb-6 px-4 py-3 rounded-xl bg-red-100 text-red-700 shadow-md text-center">
                @TempData["Error"]
            </div>
        }


        @* <!-- Filtrlər -->
        <div class="flex flex-wrap gap-4 mb-10 justify-center">
            <a asp-action="Index" asp-controller="Course"
               class="bg-blue-600 text-white px-6 py-2 rounded-lg shadow-md font-medium">
                Hamısı
            </a>
            @foreach (var item in ViewBag.Categories)
            {
                <a asp-action="Index" asp-controller="Course" asp-route-categoryId="@item.Id"
                   class="bg-white border border-gray-200 text-gray-700 px-6 py-2 rounded-lg hover:bg-gray-50 transition font-medium">
                    @item.Name
                </a>
            }
        </div> *@

        <!-- Kurslar Konteyneri (id="courseContainer" əlavə edildi) -->
        <div id="courseContainer" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
            @foreach (var item in Model)
            {
                <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-xl transition-all duration-300 group flex flex-col">
                    <div class="relative overflow-hidden">
                        <img src="@item.ImageUrl" class="w-full h-48 object-cover group-hover:scale-110 transition-transform duration-500" alt="@item.Title">
                        <div class="absolute top-4 left-4">
                            @if (item.IsPopular)
                            {
                                <span class="bg-blue-600 text-white text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-wider">
                                    Populyar
                                </span>
                            }
                        </div>
                    </div>
                    <div class="p-6 flex flex-col flex-grow">
                        <span class="text-xs font-semibold text-blue-500 uppercase tracking-wide">@item.CategoryName</span>
                        <h3 class="font-bold text-xl mt-2 mb-4 text-gray-800">@item.Title</h3>

                        <div class="mt-auto">
                            <div class="flex items-center justify-between mb-4 pt-4 border-t border-gray-50">
                                <div class="flex flex-col">
                                    <span class="text-xs text-gray-400 line-through">@item.Price AZN</span>
                                    <span class="text-xl font-bold text-blue-600">@item.DiscountPrice AZN</span>
                                </div>
                                <form asp-controller="Cart" asp-action="AddToCart" method="post" asp-route-courseId="@item.Id">
                                    <button type="submit" class="bg-gray-900 text-white p-2.5 rounded-lg hover:bg-blue-600 transition flex items-center justify-center" title="Səbətə at">
                                        <i class="fas fa-shopping-cart"></i>
                                    </button>
                                </form>
                            </div>

                            <a asp-action="Index" asp-controller="CourseDetail" asp-route-id="@item.Id" class="w-full inline-flex items-center justify-center gap-2 bg-blue-50 text-blue-700 px-4 py-2.5 rounded-xl font-bold text-sm hover:bg-blue-600 hover:text-white transition-colors duration-300">
                                Ətraflı bax <i class="fas fa-arrow-right text-xs"></i>
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</main>

