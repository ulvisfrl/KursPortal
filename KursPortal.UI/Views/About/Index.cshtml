
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<header class="relative pt-44 pb-24 overflow-hidden">
    <div class="shape-blob bg-indigo-400 w-[500px] h-[500px] -top-24 -left-24 rounded-full"></div>
    <div class="shape-blob bg-cyan-400 w-[400px] h-[400px] bottom-0 -right-12 rounded-full"></div>

    <div class="container mx-auto px-6 text-center">
        <span class="inline-block bg-indigo-50 text-indigo-600 px-4 py-1.5 rounded-full text-sm font-bold mb-6">Biz Kimik?</span>
        <h1 class="text-4xl lg:text-6xl font-extrabold text-slate-900 mb-8 leading-tight">
            Gələcəyin Təhsilini <br>
            <span class="bg-clip-text text-transparent bg-gradient-to-r from-indigo-600 to-cyan-500">Bu Gün Qururuq</span>
        </h1>
        <p class="text-lg text-slate-600 max-w-3xl mx-auto leading-relaxed">
            KursPortal, Azərbaycanda rəqəmsal bacarıqların artırılması və keyfiyyətli təhsilin hamı üçün əlçatan olması məqsədilə yaradılmış yeni nəsil təhsil platformasıdır.
        </p>
    </div>
</header>
<section class="container mx-auto px-6 mb-32">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="relative">
            <div class="absolute -inset-4 bg-gradient-to-r from-indigo-500 to-cyan-500 rounded-[2.5rem] blur opacity-20"></div>
            <img src="https://images.unsplash.com/photo-1522202176988-66273c2fd55f?auto=format&fit=crop&q=80&w=800"
                 alt="Team Working"
                 class="relative rounded-[2rem] shadow-2xl border border-white/50 object-cover h-[500px] w-full">
        </div>

        <div class="space-y-10">
            <div>
                <h2 class="text-3xl font-bold mb-6 flex items-center gap-4">
                    <span class="w-12 h-1 bg-indigo-600 rounded-full"></span>
                    Missiyamız
                </h2>
                <p class="text-slate-600 text-lg leading-relaxed">
                    Tələbələrimizi yalnız nəzəri biliklərlə deyil, həm də iş dünyasının tələb etdiyi real təcrübə ilə təmin etmək. Biz inanırıq ki, düzgün təhsil hər bir fərdin həyatını kökündən dəyişdirə bilər.
                </p>
            </div>
        </div>
    </div>
</section>

<section class="bg-slate-100/50 py-32">
    <div class="container mx-auto px-6">
        <div class="text-center mb-20">
            <h2 class="text-3xl lg:text-4xl font-extrabold mb-4">Dəyərlərimiz</h2>
            <p class="text-slate-500">Bizi fərqləndirən və hər gün inkişaf etdirən prinsiplər.</p>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
            <div class="value-card bg-white p-10 rounded-[2.5rem] border border-slate-100">
                <div class="w-16 h-16 bg-indigo-50 text-indigo-600 rounded-2xl flex items-center justify-center text-2xl mb-8">
                    <i class="fas fa-lightbulb"></i>
                </div>
                <h3 class="text-xl font-bold mb-4">İnnovasiya</h3>
                <p class="text-slate-500 leading-relaxed">
                    Həmişə ən yeni texnologiyaları və tədris metodlarını dərslərimizə inteqrasiya edirik.
                </p>
            </div>

            <div class="value-card bg-white p-10 rounded-[2.5rem] border border-slate-100">
                <div class="w-16 h-16 bg-cyan-50 text-cyan-600 rounded-2xl flex items-center justify-center text-2xl mb-8">
                    <i class="fas fa-users"></i>
                </div>
                <h3 class="text-xl font-bold mb-4">İcma Gündəlikli</h3>
                <p class="text-slate-500 leading-relaxed">
                    Tələbələrimiz arasında güclü bir şəbəkə və qarşılıqlı dəstək mühiti yaradırıq.
                </p>
            </div>

            <div class="value-card bg-white p-10 rounded-[2.5rem] border border-slate-100">
                <div class="w-16 h-16 bg-rose-50 text-rose-600 rounded-2xl flex items-center justify-center text-2xl mb-8">
                    <i class="fas fa-shield-alt"></i>
                </div>
                <h3 class="text-xl font-bold mb-4">Keyfiyyət</h3>
                <p class="text-slate-500 leading-relaxed">
                    Təqdim etdiyimiz hər bir dərsin və tapşırığın ən yüksək standartlara cavab verməsinə zəmanət veririk.
                </p>
            </div>
        </div>
    </div>
</section>

