@model ChangePasswordVM

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<br />
<br />
<div class="min-h-screen flex flex-col md:flex-row">
    <!-- Sidebar -->
    <aside class="w-full md:w-72 bg-white border-r border-gray-200 flex flex-col">
        <div class="p-8">
            <br />
            <br />
            <nav class="space-y-1">
                <a href="/Profile/Index" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-600 hover:bg-gray-50 font-medium transition-colors">
                    <i class="fas fa-user-circle"></i>
                    Məlumatlarım
                </a>
                <a href="/Profile/ChangePassword" class="flex items-center gap-3 px-4 py-3 rounded-lg bg-indigo-50 text-indigo-700 font-semibold transition-colors">
                    <i class="fas fa-shield-alt"></i>
                    Şifrəni Yenilə
                </a>
            </nav>
        </div>

        <div class="mt-auto p-8 border-t border-gray-100">
            <button class="flex items-center gap-3 text-red-500 font-semibold hover:opacity-80 transition-opacity">
                <i class="fas fa-sign-out-alt"></i>
                Çıxış
            </button>
        </div>
    </aside>

    <!-- Content -->
    <main class="flex-1 p-6 md:p-12 flex justify-center items-start">
        <!-- flex və justify-center əlavə edildi ki, daxilindəki div mərkəzə gəlsin -->

        <div class="w-full max-w-2xl mt-10">
            <!-- max-w-2xl genişliyi saxlayır, mərkəzdə durur -->
            <header class="mb-10 text-center md:text-left">
                <!-- Başlığı da mərkəzləmək olar -->
                <h1 class="text-3xl font-bold text-gray-900">Şifrəni Yenilə</h1>
                <p class="text-gray-500 mt-2">Hesabınızın təhlükəsizliyi üçün güclü bir şifrə seçin.</p>
            </header>

            <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
                <form asp-action="ChangePassword" asp-controller="Profile" method="post" class="p-8 space-y-6">
                    <!-- İnputlar buraya gəlir -->
                    <div class="space-y-2">
                        <label class="text-sm font-semibold text-gray-700">Cari Şifrə</label>
                        <input asp-for="CurrentPassword" type="password"  placeholder="••••••••" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-indigo-500 outline-none transition-all">
                    </div>

                    <div class="space-y-2">
                        <label class="text-sm font-semibold text-gray-700">Yeni Şifrə</label>
                        <input asp-for="NewPassword" type="password"  placeholder="••••••••" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-indigo-500 outline-none transition-all">
                    </div>

                    <div class="space-y-2">
                        <label class="text-sm font-semibold text-gray-700">Yeni Şifrə (Təkrar)</label>
                        <input asp-for="ConfirmPassword" type="password" placeholder="••••••••" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-indigo-500 outline-none transition-all">
                    </div>
                    <div class="pt-4 text-right">
                        <!-- Düyməni sağa və ya mərkəzə qoymaq olar -->
                        <button type="submit" class="w-full md:w-auto bg-gray-900 text-white px-10 py-3 rounded-xl font-bold hover:bg-black transition-all shadow-md">
                            Şifrəni Dəyişdir
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </main>

</div>

