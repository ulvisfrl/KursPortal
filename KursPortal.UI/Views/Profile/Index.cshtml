@model UserProfileVM

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<br />
<br />
<div class="min-h-screen flex flex-col md:flex-row">
    <!-- Sidebar -->
    <aside class="w-full md:w-72 bg-white border-r border-gray-200 flex flex-col">
        <div class="p-8">
            <br />
            <br />
            <nav class="space-y-1">
                <a asp-controller="Profile" asp-action="Index" class="flex items-center gap-3 px-4 py-3 rounded-lg bg-indigo-50 text-indigo-700 font-semibold transition-colors">
                    <i class="fas fa-user-circle"></i>
                    Məlumatlarım
                </a>
                <a asp-controller="Profile" asp-action="ChangePassword" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-600 hover:bg-gray-50 font-medium transition-colors">
                    <i class="fas fa-shield-alt"></i>
                    Şifrəni Yenilə
                </a>
            </nav>
        </div>

        <div class="mt-auto p-8 border-t border-gray-100">
            <button class="flex items-center gap-3 text-red-500 font-semibold hover:opacity-80 transition-opacity">
                <i class="fas fa-sign-out-alt"></i>
                Çıxış
            </button>
        </div>
    </aside>

    <!-- Content -->
    <main class="flex-1 p-6 md:p-12 flex justify-center items-start">
        <div class="w-full max-w-2xl mt-10">
            <header class="mb-10">
                <h1 class="text-3xl font-bold text-gray-900">Məlumatlarım</h1>
                <p class="text-gray-500 mt-2">Profil məlumatlarınızı buradan redaktə edə bilərsiniz.</p>
            </header>

            <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
                <form action="#" method="POST" class="p-8 space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-2">
                            <label class="text-sm font-semibold text-gray-700">Ad</label>
                            <input type="text" asp-for="FirstName" placeholder="Adınız" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-all">
                        </div>
                        <div class="space-y-2">
                            <label class="text-sm font-semibold text-gray-700">Soyad</label>
                            <input type="text" asp-for="LastName" placeholder="Soyadınız" class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-all">
                        </div>
                    </div>

                    <div class="space-y-2">
                        <label class="text-sm font-semibold text-gray-700">Bioqrafiya</label>
                        <textarea asp-for="Bio" rows="4" placeholder="Özünüz haqqında qısa məlumat..." class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-all resize-none"></textarea>
                    </div>

                    <div class="pt-4">
                        <button type="submit" class="w-full md:w-auto bg-indigo-600 text-white px-10 py-3 rounded-xl font-bold hover:bg-indigo-700 transition-all shadow-md shadow-indigo-100">
                            Yadda saxla
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </main>
</div>