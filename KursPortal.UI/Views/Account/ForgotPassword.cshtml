<main class="flex-grow flex items-center justify-center">
    <div class="bg-white p-10 rounded-2xl shadow-xl w-full max-w-md">
        <h2 class="text-3xl font-bold mb-6 text-center">Şifrə Sıfırlama</h2>
        <form asp-action="ForgotPassword" asp-controller="Account" class="space-y-4">
            <div asp-validation-summary="All" class="text-red-500 mb-4"></div>
            <input type="email" name="email" placeholder="Email" class="w-full p-3 border rounded-lg">
            <button type="submit" class="w-full bg-blue-600 text-white py-3 rounded-lg font-bold">Göndər</button>
        </form>
    </div>
</main>

