@using KursPortal.UI.ViewModels.AuthViewModel
@model RegisterVM

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<br />
<br />
<main class="flex-grow flex items-center justify-center py-16 px-4">
    <div class="bg-white p-8 md:p-12 rounded-2xl shadow-xl w-full max-w-lg border border-gray-100">
        <div class="text-center mb-10">
            <h2 class="text-3xl font-bold text-gray-900">Yeni Hesab Yarat</h2>
            <p class="text-gray-500 mt-2">EduMaster ailəsinə qoşulun və öyrənməyə başlayın.</p>
        </div>

        <form asp-action="Register" asp-controller="Account" class="space-y-5">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1">Adınız</label>
                    <input type="text" asp-for="FirsName" placeholder="Ad" class="w-full p-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:outline-none transition" required>
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1">Soyadınız</label>
                    <input type="text" asp-for="LastName" placeholder="Soyad" class="w-full p-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:outline-none transition" required>
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1">İstifadəçi adınız</label>
                    <input type="text" asp-for="UserName" placeholder="Soyad" class="w-full p-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:outline-none transition" required>
                </div>
            </div>

            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">Email Ünvanı</label>
                <input type="email" asp-for="Email" placeholder="nümunə@mail.com" class="w-full p-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:outline-none transition" required>
            </div>

            <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">Şifrə</label>
                <div class="relative">
                    <input type="password" asp-for="Password" placeholder="••••••••" class="w-full p-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:outline-none transition" required>
                    <button type="button" class="absolute right-3 top-3.5 text-gray-400 hover:text-gray-600">
                        <i class="fas fa-eye"></i>
                    </button>
                </div>
                <label class="block text-sm font-semibold text-gray-700 mb-1">Şifrəyi təsdiqlə</label>
                <div class="relative">
                    <input type="password" asp-for="ConfirmPassword" placeholder="••••••••" class="w-full p-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:outline-none transition" required>
                    <button type="button" class="absolute right-3 top-3.5 text-gray-400 hover:text-gray-600">
                        <i class="fas fa-eye"></i>
                    </button>
                </div>
            </div>

            <div class="flex items-start">
                <div class="flex items-center h-5">
                    <input id="terms" type="checkbox" class="w-4 h-4 border border-gray-300 rounded bg-gray-50 focus:ring-3 focus:ring-blue-300" required>
                </div>
                <label for="terms" class="ml-2 text-sm text-gray-500">
                    <a href="#" class="text-blue-600 hover:underline">İstifadəçi şərtləri</a> ilə razıyam.
                </label>
            </div>

            <button class="w-full bg-blue-600 text-white py-4 rounded-xl font-bold hover:bg-blue-700 shadow-lg shadow-blue-200 transition-all active:scale-[0.98]">
                Qeydiyyatı Tamamla
            </button>
        </form>

        <div class="mt-8 text-center pt-6 border-t border-gray-100">
            <p class="text-gray-600">Artıq hesabınız var? <a href="login.html" class="text-blue-600 font-bold hover:underline">Daxil olun</a></p>
        </div>
    </div>
</main>

