@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    body {
        font-family: 'Plus Jakarta Sans', sans-serif;
        background-color: #F8FAFC;
    }

    .view-section {
        display: none;
    }

    #payment-view:target,
    :not(:target) ~ main #payment-view {
        display: block;
    }

    #success-view:target {
        display: block;
    }

        #success-view:target ~ #payment-view {
            display: none !important;
        }

    .card-shadow {
        box-shadow: 0 20px 50px -12px rgba(79, 70, 229, 0.1);
    }
</style>

<nav class="bg-white/80 backdrop-blur-md border-b border-slate-100 sticky top-0 z-50">
    <div class="max-w-4xl mx-auto px-6 h-16 flex justify-between items-center">
        <div class="flex items-center gap-2">
            <div class="bg-indigo-600 p-1.5 rounded-lg text-white">
                <i class="fas fa-shield-halved text-sm"></i>
            </div>
            <span class="font-extrabold text-lg tracking-tight">KursPortal <span class="text-indigo-600">Secure</span></span>
        </div>
        <div class="flex items-center gap-2 text-slate-400 text-xs font-bold uppercase tracking-widest">
            <i class="fas fa-lock"></i> SSL Şifrələmə
        </div>
    </div>
</nav>

<main class="max-w-xl mx-auto px-6 py-12 md:py-20">

    <section id="success-view" class="view-section animate-in fade-in zoom-in duration-500">
        <div class="bg-white p-10 md:p-16 rounded-[3rem] text-center card-shadow border border-slate-50">
            <div class="w-24 h-24 bg-green-100 text-green-600 rounded-full flex items-center justify-center mx-auto mb-8 relative">
                <i class="fas fa-check text-4xl"></i>
                <div class="absolute inset-0 rounded-full border-4 border-green-500 animate-ping opacity-20"></div>
            </div>
            <h2 class="text-3xl font-black mb-4 text-slate-900">Ödəniş Uğurludur!</h2>
            <p class="text-slate-500 mb-10 leading-relaxed">
                Təşəkkür edirik! Ödənişiniz qəbul olundu. Kurs materialları artıq profilinizdə aktivdir.
            </p>
            <div class="space-y-4">
                <a href="#" class="block w-full bg-slate-900 text-white py-5 rounded-2xl font-bold hover:bg-black transition-all">
                    Təhsilə Başla
                </a>
                <p class="text-xs text-slate-400 font-medium">Sifariş nömrəsi: #KP-99281</p>
            </div>
        </div>
    </section>

    <form method="post" asp-action="CreateOrder" asp-controller="Order">
        <section id="payment-view" class="view-section animate-in fade-in slide-in-from-bottom-8 duration-700">
            <div class="bg-white rounded-[2.5rem] overflow-hidden card-shadow border border-slate-100">
                <!-- Card Header -->
                <div class="bg-slate-900 p-8 text-white">
                    <div class="flex justify-between items-start mb-8">
                        <div class="space-y-1">
                            <h3 class="text-xl font-bold tracking-tight">Kart Məlumatları</h3>
                            <p class="text-slate-400 text-xs uppercase tracking-widest font-semibold">Təhlükəsiz Ödəniş Səhifəsi</p>
                        </div>
                        <i class="fas fa-credit-card text-3xl text-slate-700"></i>
                    </div>
                    <div class="flex items-center gap-4">
                        <img src="https://upload.wikimedia.org/wikipedia/commons/5/5e/Visa_Inc._logo.svg" class="h-4 opacity-80" alt="Visa">
                        <img src="https://upload.wikimedia.org/wikipedia/commons/2/2a/Mastercard-logo.svg" class="h-6 opacity-80" alt="MasterCard">
                    </div>
                </div>

                <div class="p-8 space-y-6">
                    <div class="space-y-2">
                        <label class="text-[11px] font-extrabold text-slate-400 uppercase tracking-widest ml-1">Kart Sahibinin Adı</label>
                        <input type="text" placeholder="AD SOYAD" class="w-full px-6 py-4 rounded-2xl border border-slate-100 focus:border-indigo-500 focus:ring-4 focus:ring-indigo-50 outline-none bg-slate-50/50 transition-all font-semibold uppercase placeholder:text-slate-300">
                    </div>

                    <div class="space-y-2">
                        <label class="text-[11px] font-extrabold text-slate-400 uppercase tracking-widest ml-1">Kartın Nömrəsi</label>
                        <div class="relative">
                            <input type="text" placeholder="0000 0000 0000 0000" class="w-full px-6 py-4 rounded-2xl border border-slate-100 focus:border-indigo-500 focus:ring-4 focus:ring-indigo-50 outline-none bg-slate-50/50 transition-all font-mono tracking-widest placeholder:text-slate-300">
                            <i class="fas fa-lock absolute right-6 top-1/2 -translate-y-1/2 text-slate-200"></i>
                        </div>
                    </div>

                    <div class="grid grid-cols-2 gap-6">
                        <div class="space-y-2">
                            <label class="text-[11px] font-extrabold text-slate-400 uppercase tracking-widest ml-1">Bitmə Tarixi</label>
                            <input type="text" placeholder="AA / İİ" class="w-full px-6 py-4 rounded-2xl border border-slate-100 focus:border-indigo-500 outline-none bg-slate-50/50 transition-all text-center font-bold">
                        </div>
                        <div class="space-y-2">
                            <label class="text-[11px] font-extrabold text-slate-400 uppercase tracking-widest ml-1">CVV/CVC</label>
                            <input type="password" placeholder="***" maxlength="3" class="w-full px-6 py-4 rounded-2xl border border-slate-100 focus:border-indigo-500 outline-none bg-slate-50/50 transition-all text-center font-bold">
                        </div>
                    </div>

                    <div class="pt-4 space-y-4">
                        <div class="flex items-center justify-between px-2 mb-6">
                            <span class="text-slate-400 font-medium">Toplam ödəniş:</span>
                            <span class="text-2xl font-black text-indigo-600">@ViewBag.TotalPrice AZN</span>
                        </div>

                        <button type="submit" class="block w-full bg-indigo-600 text-white text-center py-5 rounded-2xl font-bold text-lg hover:bg-indigo-700 transition-all shadow-xl shadow-indigo-100 active:scale-[0.98]">
                            Ödənişi Tamamla
                        </button>

                        <button class="block text-center text-slate-400 text-sm font-bold hover:text-slate-600 transition-colors">
                            İmtina et
                        </button>
                    </div>
                </div>
            </div>

            <div class="mt-8 flex items-center justify-center gap-6 text-slate-300">
                <div class="flex items-center gap-2">
                    <i class="fas fa-shield-check text-xs"></i>
                    <span class="text-[10px] font-bold uppercase tracking-tighter">Secure Checkout</span>
                </div>
                <div class="w-1 h-1 bg-slate-200 rounded-full"></div>
                <div class="flex items-center gap-2">
                    <i class="fas fa-fingerprint text-xs"></i>
                    <span class="text-[10px] font-bold uppercase tracking-tighter">Verified Provider</span>
                </div>
            </div>
        </section>

    </form>
</main>

<footer class="py-10 text-center text-slate-400 text-xs font-medium">
    &copy; 2024 KursPortal Security. Bütün məlumatlar şifrələnir.
</footer>



