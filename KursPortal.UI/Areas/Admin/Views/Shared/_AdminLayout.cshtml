<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EduMaster Admin - Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap');
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

        .glass {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(10px);
        }

        .sidebar-item-active {
            background: linear-gradient(90deg, rgba(37, 99, 235, 0.1) 0%, rgba(37, 99, 235, 0) 100%);
            border-right: 4px solid #2563eb;
            color: #2563eb !important;
        }
    </style>
</head>
<body class="bg-[#F8FAFC]">

    <div class="flex min-h-screen">
        <!-- SIDEBAR -->
        <aside class="w-72 bg-white border-r border-gray-100 flex flex-col sticky top-0 h-screen z-40">
            <div class="p-8">
                <a href="index.html" class="flex items-center space-x-3 group">
                    <div class="bg-blue-600 p-2.5 rounded-xl shadow-lg shadow-blue-200 group-hover:rotate-12 transition-transform">
                        <i class="fas fa-graduation-cap text-white text-xl"></i>
                    </div>
                    <span class="text-2xl font-extrabold text-slate-800 tracking-tighter">EduMaster</span>
                </a>
            </div>

            <nav class="flex-grow px-4 space-y-2 mt-4">
                <p class="text-[10px] font-bold text-gray-400 uppercase tracking-[2px] px-4 mb-4">Əsas Menyu</p>
                <a href="#" class="flex items-center space-x-3 px-4 py-3.5 rounded-xl text-gray-500 hover:bg-gray-50 transition-all font-semibold">
                    <i class="fas fa-th-large w-5"></i>
                    <span>Dashboard</span>
                </a>
                <a href="/Admin/Course/Index" class="flex items-center space-x-3 px-4 py-3.5 rounded-xl sidebar-item-active font-bold">
                    <i class="fas fa-book-open w-5"></i>
                    <span>Kurslar</span>
                </a>
                <a href="/Admin/Category/Index" class="flex items-center space-x-3 px-4 py-3.5 rounded-xl text-gray-500 hover:bg-gray-50 transition-all font-semibold">
                    <i class="fas fa-layer-group w-5"></i>
                    <span>Kateqoriyalar</span>
                </a>
                <a href="#" class="flex items-center space-x-3 px-4 py-3.5 rounded-xl text-gray-500 hover:bg-gray-50 transition-all font-semibold">
                    <i class="fas fa-users w-5"></i>
                    <span>Tələbələr</span>
                </a>

                <p class="text-[10px] font-bold text-gray-400 uppercase tracking-[2px] px-4 mt-10 mb-4">Sistem</p>
                <a href="#" class="flex items-center space-x-3 px-4 py-3.5 rounded-xl text-gray-500 hover:bg-gray-50 transition-all font-semibold">
                    <i class="fas fa-cog w-5"></i>
                    <span>Ayarlar</span>
                </a>
            </nav>

            <div class="p-6 mt-auto">
                <div class="bg-blue-600 rounded-[1.5rem] p-6 text-white relative overflow-hidden shadow-xl shadow-blue-100">
                    <i class="fas fa-bolt absolute -right-2 -bottom-2 text-6xl opacity-20"></i>
                    <p class="text-xs font-bold opacity-80 uppercase tracking-widest mb-1">Premium</p>
                    <p class="text-sm font-bold leading-tight mb-4">Daha çox funksiya əldə et!</p>
                    <button class="bg-white text-blue-600 px-4 py-2 rounded-xl text-xs font-black hover:bg-blue-50 transition">Yüksəlt</button>
                </div>
            </div>
        </aside>

        <!-- MAIN CONTENT AREA -->
        <main class="flex-grow flex flex-col">

            <!-- TOP HEADER -->
            <header class="h-24 glass border-b border-gray-100 flex items-center justify-between px-10 sticky top-0 z-30">
                <!-- Search -->
                <div class="relative w-96 hidden md:block">
                    <i class="fas fa-search absolute left-4 top-1/2 -translate-y-1/2 text-gray-400"></i>
                    <input type="text" placeholder="Kurs, müəllim və ya tələbə axtar..."
                           class="w-full bg-gray-100 border-none rounded-2xl py-3 pl-12 pr-4 focus:ring-2 focus:ring-blue-500 transition text-sm font-medium">
                </div>

                <div class="flex items-center space-x-6">
                    <div class="flex space-x-3">
                        <button class="w-11 h-11 flex items-center justify-center rounded-xl bg-white border border-gray-100 text-gray-500 hover:text-blue-600 hover:border-blue-200 transition shadow-sm">
                            <i class="far fa-bell text-lg"></i>
                        </button>
                        <button class="w-11 h-11 flex items-center justify-center rounded-xl bg-white border border-gray-100 text-gray-500 hover:text-blue-600 hover:border-blue-200 transition shadow-sm">
                            <i class="far fa-envelope text-lg"></i>
                        </button>
                    </div>

                    <div class="w-px h-8 bg-gray-200"></div>

                    <!-- PROFILE DROPDOWN -->
                    <div class="relative group">
                        <button class="flex items-center space-x-3 focus:outline-none py-2">
                            <div class="text-right hidden sm:block">
                                <p class="text-sm font-extrabold text-gray-800 leading-none">Ülvi Səfərli</p>
                                <p class="text-[10px] text-blue-600 font-bold uppercase mt-1">Super Admin</p>
                            </div>
                            <div class="relative">
                                <img src="https://ui-avatars.com/api/?name=Ulvi+Safarli&background=2563eb&color=fff&bold=true"
                                     class="w-11 h-11 rounded-[14px] border-2 border-white shadow-md group-hover:border-blue-500 transition-all" alt="Admin">
                                <div class="absolute -bottom-1 -right-1 w-4 h-4 bg-green-500 border-2 border-white rounded-full"></div>
                            </div>
                            <i class="fas fa-chevron-down text-[10px] text-gray-400 group-hover:text-blue-600 transition-transform group-hover:rotate-180"></i>
                        </button>

                        <!-- Dropdown Menu -->
                        <div class="absolute right-0 w-64 mt-2 origin-top-right bg-white border border-gray-100 rounded-[1.5rem] shadow-2xl shadow-gray-200/50 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 z-50">
                            <div class="p-3">
                                <div class="px-4 py-4 bg-gray-50 rounded-2xl mb-2">
                                    <p class="text-xs text-gray-400 font-bold uppercase tracking-wider mb-1">Hesab</p>
                                    <p class="text-sm font-bold text-gray-800 truncate">ulvi@edumaster.az</p>
                                </div>
                                <a href="#" class="flex items-center space-x-3 p-3 rounded-xl hover:bg-blue-50 text-gray-600 hover:text-blue-600 transition group/item">
                                    <div class="w-8 h-8 rounded-lg bg-gray-100 group-hover/item:bg-blue-100 flex items-center justify-center transition">
                                        <i class="fas fa-user-circle"></i>
                                    </div>
                                    <span class="text-sm font-bold">Profilim</span>
                                </a>
                                <a href="#" class="flex items-center space-x-3 p-3 rounded-xl hover:bg-blue-50 text-gray-600 hover:text-blue-600 transition group/item">
                                    <div class="w-8 h-8 rounded-lg bg-gray-100 group-hover/item:bg-blue-100 flex items-center justify-center transition">
                                        <i class="fas fa-wallet"></i>
                                    </div>
                                    <span class="text-sm font-bold">Balans</span>
                                </a>
                                <div class="h-px bg-gray-50 my-2"></div>
                                <a href="index.html" class="flex items-center space-x-3 p-3 rounded-xl hover:bg-red-50 text-red-500 transition group/item">
                                    <div class="w-8 h-8 rounded-lg bg-red-100 flex items-center justify-center transition">
                                        <i class="fas fa-power-off"></i>
                                    </div>
                                    <span class="text-sm font-bold">Çıxış et</span>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </header>

            <!-- DASHBOARD CONTENT -->
            @RenderBody()
        </main>
    </div>

</body>
</html>