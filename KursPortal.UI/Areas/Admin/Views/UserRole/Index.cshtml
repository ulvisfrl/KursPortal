@model List<UserRoleVM>

@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="p-10">

    <!-- PAGE HEADER -->
    <div class="flex items-center justify-between mb-10">
        <div>
            <h1 class="text-3xl font-extrabold text-slate-800 tracking-tight">
                Rol İdarəetməsi
            </h1>
            <p class="text-gray-500 mt-2 text-sm font-medium">
                İstifadəçilərə rol əlavə et və ya rolları idarə et
            </p>
        </div>

        <button class="bg-blue-600 hover:bg-blue-700 transition text-white px-6 py-3 rounded-2xl font-bold shadow-lg shadow-blue-200">
            <i class="fas fa-user-shield mr-2"></i>
            Rol Paneli
        </button>
    </div>

    <!-- TABLE -->
    <div class="bg-white rounded-[2rem] shadow-sm border border-gray-100 overflow-hidden">

        <!-- TABLE HEADER -->
        <div class="grid grid-cols-12 gap-4 px-8 py-5 border-b border-gray-100 bg-gray-50">

            <div class="col-span-4">
                <p class="text-xs font-extrabold uppercase tracking-widest text-gray-400">
                    İstifadəçi
                </p>
            </div>

            <div class="col-span-3">
                <p class="text-xs font-extrabold uppercase tracking-widest text-gray-400">
                    Email
                </p>
            </div>

            <div class="col-span-3">
                <p class="text-xs font-extrabold uppercase tracking-widest text-gray-400">
                    Rollar
                </p>
            </div>

            <div class="col-span-2 text-right">
                <p class="text-xs font-extrabold uppercase tracking-widest text-gray-400">
                    Əməliyyat
                </p>
            </div>
        </div>

        <!-- USERS -->
        @foreach (var item in Model)
        {
            <div class="grid grid-cols-12 gap-4 px-8 py-6 border-b border-gray-50 items-center hover:bg-gray-50 transition">

                <!-- USER -->
                <div class="col-span-4 flex items-center space-x-4">

                    <img src="https://ui-avatars.com/api/?name=@item.FullName&background=2563eb&color=fff"
                         class="w-14 h-14 rounded-2xl shadow-md" />

                    <div>
                        <h3 class="font-extrabold text-slate-800 text-sm">
                            @item.FullName
                        </h3>

                        <p class="text-xs text-gray-400 font-semibold mt-1">
                            ID: @item.Id
                        </p>
                    </div>
                </div>

                <!-- EMAIL -->
                <div class="col-span-3">
                    <p class="text-sm font-bold text-gray-600">
                        @item.Email
                    </p>
                </div>

                <!-- ROLES -->
                <div class="col-span-3 flex flex-wrap gap-2">

                    @foreach (var role in item.UserRoles)
                    {
                        <span class="px-3 py-1 rounded-xl bg-blue-100 text-blue-700 text-xs font-extrabold">
                            @role
                        </span>
                    }

                </div>

                <!-- ACTION -->
                <div class="col-span-2 text-right">

                    <a href="/Admin/UserRole/AssignRole/@item.Id"
                       class="inline-flex items-center px-5 py-2.5 rounded-xl bg-slate-800 hover:bg-black text-white text-sm font-bold transition shadow-lg shadow-gray-200">

                        <i class="fas fa-pen mr-2 text-xs"></i>
                        Rol Təyin Et
                    </a>

                </div>
            </div>
        }

    </div>
</div>

