@model List<ResultCategoryVM>

@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<header class="h-20 glass border-b border-gray-100 flex items-center justify-between px-10 sticky top-0 z-30">
    <h1 class="text-xl font-extrabold text-slate-800">Kateqoriyaların İdarə Edilməsi</h1>

    <div class="flex items-center space-x-4">
        <a href="/Admin/Category/Create" class="bg-blue-600 text-white px-5 py-2.5 rounded-xl font-bold hover:bg-blue-700 shadow-lg shadow-blue-200 transition flex items-center space-x-2 text-sm">
            <i class="fas fa-plus"></i>
            <span>Yeni Kateqoriya</span>
        </a>
    </div>
</header>

<div class="p-10 space-y-8">
    <!-- CATEGORY STATS -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white p-6 rounded-[2rem] border border-gray-100 shadow-sm flex items-center space-x-4">
            <div class="w-14 h-14 bg-blue-50 rounded-2xl flex items-center justify-center text-blue-600">
                <i class="fas fa-tags text-2xl"></i>
            </div>
            <div>
                <p class="text-xs font-bold text-gray-400 uppercase tracking-widest">Cəmi Kateqoriya</p>
                <p class="text-2xl font-black text-slate-800">12</p>
            </div>
        </div>
        <div class="bg-white p-6 rounded-[2rem] border border-gray-100 shadow-sm flex items-center space-x-4">
            <div class="w-14 h-14 bg-green-50 rounded-2xl flex items-center justify-center text-green-600">
                <i class="fas fa-check-circle text-2xl"></i>
            </div>
            <div>
                <p class="text-xs font-bold text-gray-400 uppercase tracking-widest">Aktiv</p>
                <p class="text-2xl font-black text-slate-800">10</p>
            </div>
        </div>
        <div class="bg-white p-6 rounded-[2rem] border border-gray-100 shadow-sm flex items-center space-x-4">
            <div class="w-14 h-14 bg-orange-50 rounded-2xl flex items-center justify-center text-orange-600">
                <i class="fas fa-clock text-2xl"></i>
            </div>
            <div>
                <p class="text-xs font-bold text-gray-400 uppercase tracking-widest">Arxivlənmiş</p>
                <p class="text-2xl font-black text-slate-800">2</p>
            </div>
        </div>
    </div>

    <!-- CATEGORIES TABLE -->
    <div class="bg-white rounded-[2.5rem] border border-gray-100 shadow-xl shadow-gray-200/20 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-gray-50/50">
                        <th class="px-8 py-5 text-[10px] font-black text-gray-400 uppercase tracking-widest border-b border-gray-50">İkon</th>
                        <th class="px-8 py-5 text-[10px] font-black text-gray-400 uppercase tracking-widest border-b border-gray-50">Kateqoriya Adı</th>
                        <th class="px-8 py-5 text-[10px] font-black text-gray-400 uppercase tracking-widest border-b border-gray-50">Təsvir (Description)</th>
                        <th class="px-8 py-5 text-[10px] font-black text-gray-400 uppercase tracking-widest border-b border-gray-50 text-right">Action</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                    @foreach (var item in Model)
                    {
                        <tr class="hover:bg-gray-50/50 transition-colors group">
                            <td class="px-8 py-6">
                                <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-blue-50 to-indigo-50 flex items-center justify-center border border-blue-100 shadow-sm group-hover:scale-110 transition-transform">
                                    <i class="@item.IconUrl"></i>
                                </div>
                            </td>
                            <td class="px-8 py-6">
                                <p class="text-sm font-bold text-slate-800">@item.Name</p>
                                <span class="text-[10px] font-bold text-blue-500 uppercase">24 Kurs</span>
                            </td>
                            <td class="px-8 py-6">
                                <p class="text-sm text-gray-500 max-w-xs truncate font-medium">
                                    @item.Description
                                </p>
                            </td>
                            <td class="px-8 py-6 text-right">
                                <div class="flex justify-end space-x-2">
                                    <a asp-area="Admin"
                                       asp-controller="Category"
                                       asp-action="Update"
                                       asp-route-id="@item.Id"
                                       class="w-10 h-10 flex items-center justify-center rounded-xl bg-gray-100 text-gray-500 hover:bg-blue-600 hover:text-white transition duration-300">
                                        <i class="fas fa-pen text-xs"></i>
                                    </a>

                                    <a asp-area="Admin"
                                       asp-controller="Category"
                                       asp-action="Delete"
                                       asp-route-id="@item.Id"
                                       class="w-10 h-10 flex items-center justify-center rounded-xl bg-gray-100 text-gray-500 hover:bg-red-500 hover:text-white transition duration-300">
                                        <i class="fas fa-trash-alt text-xs"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }

                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div class="p-8 bg-gray-50/30 border-t border-gray-50 flex items-center justify-between">
            <p class="text-xs font-bold text-gray-400">Göstərilir: 1 - 3 (Cəmi 12)</p>
            <div class="flex space-x-2">
                <button class="w-10 h-10 rounded-xl border border-gray-200 flex items-center justify-center text-gray-400 hover:bg-white transition"><i class="fas fa-chevron-left text-xs"></i></button>
                <button class="w-10 h-10 rounded-xl bg-blue-600 text-white flex items-center justify-center font-bold shadow-lg shadow-blue-100">1</button>
                <button class="w-10 h-10 rounded-xl border border-gray-200 flex items-center justify-center text-gray-600 hover:bg-white font-bold transition">2</button>
                <button class="w-10 h-10 rounded-xl border border-gray-200 flex items-center justify-center text-gray-400 hover:bg-white transition"><i class="fas fa-chevron-right text-xs"></i></button>
            </div>
        </div>
    </div>
</div>

